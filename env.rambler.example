# Шаблон под Рамблер. Скопируйте в .env и вставьте пароль:
#   cp env.rambler.example .env && nano .env && chmod 600 .env
#
# В веб-почте Рамблера включите доступ для почтовых клиентов:
#   Почта → Настройки → «Программы» (или раздел про IMAP/SMTP для клиентов).
# При двухфакторной аутентификации — отдельный пароль для почтовых приложений (Rambler ID).

# Кому уйдёт CSV (можно несколько через запятую; для проверки можно указать тот же что и FROM)
SPIMEX_MAIL_TO=e.yakovleva@binagroup.ru

SPIMEX_MAIL_FROM=miklzoom@rambler.ru

SPIMEX_SMTP_HOST=smtp.rambler.ru
SPIMEX_SMTP_PORT=465
SPIMEX_SMTP_USE_SSL=1

# Логин на SMTP совпадает с полным адресом ящика Рамблер
SPIMEX_SMTP_USER=miklzoom@rambler.ru
# Вставьте пароль здесь локально только в своём файле .env (не коммитить!)
SPIMEX_SMTP_PASSWORD=
