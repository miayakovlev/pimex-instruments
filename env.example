# Скопируйте в .env на сервере и заполните (chmod 600 .env).
# Отправка через Рамблер — готовый черновик см. env.rambler.example .

# --- Почта (обязательно для отправки после выгрузки) ---
SPIMEX_MAIL_TO=recipient@company.ru
SPIMEX_MAIL_FROM=spimex-report@company.ru

SPIMEX_SMTP_HOST=smtp.company.ru
SPIMEX_SMTP_PORT=587
# Для порта 465 включите TLS сразу (без STARTTLS):
# SPIMEX_SMTP_USE_SSL=1
SPIMEX_SMTP_USER=spimex-report@company.ru
SPIMEX_SMTP_PASSWORD=

# --- Пути (по желанию) ---
# SPIMEX_URLS_FILE=/opt/spimex-instruments/urls.txt
# SPIMEX_OUTPUT_CSV=/opt/spimex-instruments/spimex_instruments.csv
# SPIMEX_REQUEST_DELAY=0.75

# Если venv не в каталоге проекта:
# SPIMEX_PYTHON=/opt/spimex-instruments/.venv/bin/python
